package main

import f "fmt"

func main() {
	var id, idGordo, idMagro int
	var peso, pesoGordo, pesoMagro float64

	f.Println("Registro de 90 bois:")

	for i := 1; i <= 90; i++ {
		f.Printf("\nBoi %d - ID: ", i)
		f.Scan(&id)
		f.Print("Peso (kg): ")
		f.Scan(&peso)

		// Inicializa no primeiro boi
		if i == 1 {
			pesoGordo = peso
			idGordo = id
			pesoMagro = peso
			idMagro = id
		}

		// Verifica boi mais gordo
		if peso > pesoGordo {
			pesoGordo = peso
			idGordo = id
		}

		// Verifica boi mais magro
		if peso < pesoMagro {
			pesoMagro = peso
			idMagro = id
		}
	}

	f.Printf("\nBoi mais gordo: ID %d com %.2f kg\n", idGordo, pesoGordo)
	f.Printf("Boi mais magro: ID %d com %.2f kg\n", idMagro, pesoMagro)
}
