package main

import (
	f "fmt"
	m "math"
)

func main() {
	s := 0.0
	denominador := 1.0

	for i := 0; i < 51; i++ {
		termo := 1.0 / (denominador * denominador * denominador)

		if i%2 == 0 {
			s += termo
		} else {
			s -= termo
		}
		denominador += 2
	}

	pi := m.Cbrt(s * 32)

	f.Printf("O valor de PI calculado com 51 termos é: %.15f\n", pi)
}
