package main

import f "fmt"

func main() {
	var n10 int
	f.Print("Digite um número inteiro positivo (base 10): ")
	f.Scan(&n10)

	if n10 < 0 {
		f.Println("Erro: O número deve ser positivo.")
		return
	}

	if n10 == 0 {
		f.Println("Base 16: 0")
		return
	}

	hexDigit := "0123456789ABCDEF"
	base16 := ""

	for n10 > 0 {
		resto := n10 % 16
		base16 = string(hexDigit[resto]) + base16
		n10 /= 16
	}

	f.Printf("Base 16: %s\n", base16)
}
