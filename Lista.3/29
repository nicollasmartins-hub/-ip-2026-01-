package main

import f "fmt"

func main() {
	var n int
	f.Print("Digite um número inteiro positivo (N): ")
	f.Scan(&n)

	if n <= 0 {
		f.Println("Erro: O número deve ser positivo.")
		return
	}

	soma := 0
	for i := 1; i <= n; i++ {
		soma += i
	}

	f.Printf("A soma de 1 até %d é: %d\n", n, soma)
}
