package main

import f "fmt"

func main() {
	var n1, n2 int
	f.Print("Digite N1 (dividendo): ")
	f.Scan(&n1)
	f.Print("Digite N2 (divisor): ")
	f.Scan(&n2)

	if n1 < 0 || n2 <= 0 {
		f.Println("Erro: Insira números inteiros positivos (N2 não pode ser zero).")
		return
	}

	quociente := 0
	resto := n1

	for resto >= n2 {
		resto -= n2
		quociente++
	}

	f.Printf("Quociente(%d, %d) = %d\n", n1, n2, quociente)
	f.Printf("Resto(%d, %d) = %d\n", n1, n2, resto)
}
