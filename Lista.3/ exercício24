package main

import f "fmt"

func main() {
	var a float64
	f.Print("Digite o valor do ângulo A (entre 0.0 e 6.3): ")
	f.Scan(&a)

	if a < 0.0 || a > 6.3 {
		f.Println("Erro: O valor deve estar entre 0.0 e 6.3.")
		return
	}

	// Cálculo manual das potências
	a3 := a * a * a
	a5 := a3 * a * a
	a7 := a5 * a * a

	senA := a - (a3 / 6) + (a5 / 120) - (a7 / 5040)

	f.Printf("Para A = %.1f, o Sen(A) é: %.6f\n", a, senA)
}
