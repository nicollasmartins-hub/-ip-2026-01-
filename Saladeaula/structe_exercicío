package main

import f "fmt"

type p struct {
	nome string
	altura float64
	pesoideal float64
}
func main() {
	var listadepessoas []p

	f.Println("---- Cadastro de Pessoas (Digite 'FIM' no nome para sair)----")
	for {
		var n string
		var alt float64

		f.Print("\nDigite o nome: ")
		f.Scan(&n)
		if n == "FIM" {
			break
		}
		f.Print("Digite a altura: ")
		f.Scan(&alt)

		ideal := (72.7 * alt) - 58.0
		novaPessoa := p{nome: n, altura: alt, pesoideal: ideal}
		listadepessoas = append(listadepessoas, novaPessoa)
	}	
	f.Println("\n---- Lista de Resultados ----")
	for _, p := range listadepessoas {
		f.Printf("Nome: %s, Altura: %.2f, Peso Ideal: %.2f\n", p.nome, p.altura, p.pesoideal)
	}
}
