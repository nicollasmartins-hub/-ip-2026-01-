package main

import f "fmt"

func main() {
	var X, Y, Z float64

	f.Print("escreva o valor de X: ")
	f.Scanln(&X)

	f.Print("escreva o valor de Y: ")
	f.Scanln(&Y)

	f.Print("escreva o valor de Z: ")
	f.Scanln(&Z)

	resultado := MEDIA(X, Y, Z)

	f.Printf("A media de %.2f, %.2f e %.2f é %.2f\n ", X, Y, Z, resultado)
}

func MEDIA(X, Y, Z float64) float64 {
	return (X + Y + Z) / 3.0
}
