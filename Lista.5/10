package main

import f "fmt"

func main() {
	vetor := make([]uint64, 50)

	vetor[0] = 1
	vetor[1] = 1

	for i := 2; i < 50; i++ {
		vetor[i] = vetor[i-1] + vetor[i-2]
	}

	f.Println("Os primeiros 50 termos da série de Fibonacci:")
	for _, valor := range vetor {
		f.Printf("%d ", valor)
	}
	f.Println()
}
