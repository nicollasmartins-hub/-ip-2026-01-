package main

import f "fmt"

func main() {
	vetor := make([]int, 10)

	f.Println("Digite 10 números:")
	for i := 0; i < 10; i++ {
		f.Printf("Posição %d: ", i)
		f.Scan(&vetor[i])
	}

	menor := vetor[0]
	posicao := 0

	for i := 1; i < 10; i++ {
		if vetor[i] < menor {
			menor = vetor[i]
			posicao = i
		}
	}

	f.Printf("O menor elemento do vetor é %d e sua posição dentro do vetor é: %d\n", menor, posicao)
}
