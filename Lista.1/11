package main

import (
	"fmt"
)

func main() {
	var numero int

	// Aviso para o usuário saber o que digitar
	fmt.Print("Digite um número inteiro: ")
	fmt.Scan(&numero)

	// Verifica se o resto da divisão por 3 E por 5 é igual a zero
	if numero%3 == 0 && numero%5 == 0 {
		fmt.Println("O NUMERO E DIVISIVEL")
	} else {
		fmt.Println("O NUMERO NAO E DIVISIVEL")
	}
}
