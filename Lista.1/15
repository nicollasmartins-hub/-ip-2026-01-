package main

import (
	"fmt"
)

func main() {
	var n int

	// PASSO 1: Aviso para o usuário saber o que digitar
	fmt.Print("Digite um valor para N (entre 5 e 2000): ")
	
	// PASSO 2: Leitura do número inteiro N
	_, err := fmt.Scan(&n)

	// PASSO 3: Validação básica (opcional, mas boa prática)
	if err != nil {
		fmt.Println("Erro: Digite um número inteiro válido.")
		return
	}

	// PASSO 4: O Laço de Repetição (Loop)
	// Começamos em 1 e vamos até N (i <= n)
	for i := 1; i <= n; i++ {
		
		// PASSO 5: Verificar se o número é PAR
		// O operador % (módulo) pega o resto da divisão por 2. 
		// Se o resto for 0, o número é par.
		if i%2 == 0 {
			
			// PASSO 6: Calcular o quadrado e imprimir
			// i*i calcula o quadrado do número atual
			fmt.Printf("%d^2 = %d\n", i, i*i)
		}
	}
}
