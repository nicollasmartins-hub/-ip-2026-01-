package main

import (
	"fmt"
	"log"
)

func main() {
	var n1, n2, n3 float64

	// O Scan retorna quantos itens leu e se houve erro
	_, err := fmt.Scan(&n1, &n2, &n3)
	
	if err != nil {
		log.Fatal("Erro na leitura:", err)
	}

	media := (n1 + n2 + n3) / 3

	fmt.Printf("MEDIA = %.2f\n", media)

	if media >= 6.0 {
		fmt.Println("APROVADO")
	} else {
		fmt.Println("REPROVADO")
	}
}
