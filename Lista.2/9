package main

import f "fmt"

func main() {
	var valorCompra, valorVenda float64
	f.Print("Digite o valor de compra:  R$")
	f.Scan(&valorCompra)

	if valorCompra <= 0 {
		f.Println("Valor de compra inválido. O valor deve ser maior que zero.")
		return
	}

	if valorCompra < 10 {
		valorVenda = valorCompra * 1.7
	} else if valorCompra >= 10 && valorCompra <= 30 {
		valorVenda = valorCompra * 1.5
	} else {
		valorVenda = valorCompra * 1.3
	}
	f.Printf("Valor de compra:  R$ %.2f\n", valorCompra)
	f.Printf("Valor de venda:  R$ %.2f\n", valorVenda)
}
